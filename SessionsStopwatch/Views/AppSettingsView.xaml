<UserControl x:Class="SessionsStopwatch.Views.AppSettingsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:SessionsStopwatch.Views"
             mc:Ignorable="d" 
             d:DesignHeight="90" d:DesignWidth="250">
    <Grid>
        <StackPanel>
            <CheckBox Content="Start stopwatch on session start."
                      ToolTip="Automatically starts stopwatch when user logs in. Otherwise user needs to press start button."
                      IsChecked="{Binding AutoStartOnSession, Mode=TwoWay}"
                      Background="{StaticResource ButtonBrush}"
                      />
            <CheckBox Content="Limit to monitor bounds."
                      ToolTip="When dragging the window do you want it to be within monitor bounds?"
                      IsChecked="{Binding LimitToMonitorBounds, Mode=TwoWay}"
                      Background="{StaticResource ButtonBrush}"
                      />
            <CheckBox Content="Startup."
                      ToolTip="Launch app on system startup."
                      IsChecked="{Binding Startup, Mode=TwoWay}"
                      Background="{StaticResource ButtonBrush}"
                      />
        </StackPanel>
    </Grid>
</UserControl>
