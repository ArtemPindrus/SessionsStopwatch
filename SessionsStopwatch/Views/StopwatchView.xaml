<UserControl
    x:Class="SessionsStopwatch.Views.StopwatchView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="clr-namespace:SessionsStopwatch.Views"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    d:DesignHeight="100"
    d:DesignWidth="200"
    Background="{StaticResource AppMeatBrush}"
    mc:Ignorable="d">
    <Viewbox>
        <StackPanel Margin="1" Orientation="Horizontal">
            <Button
                HorizontalAlignment="Left"
                Command="{Binding RestartStopwatchCommand}"
                Style="{StaticResource MeatButton}"
                ToolTip="Restart Stopwatch">
                <Image Source="\Icons\Reset.png" />
            </Button>

            <TextBlock
                HorizontalAlignment="Center"
                VerticalAlignment="Center"
                Text="{Binding ElapsedTime, Mode=OneWay}" />
        </StackPanel>
    </Viewbox>
</UserControl>
