<UserControl
    x:Class="SessionsStopwatch.Views.StartStopwatchView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="clr-namespace:SessionsStopwatch.Views"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    d:DesignHeight="10"
    d:DesignWidth="20"
    Background="{StaticResource BackgroundColor}"
    mc:Ignorable="d">
    <Viewbox>
        <Button Command="{Binding StartStopwatchCommand}" Style="{StaticResource MeatButton}">
            <Image RenderOptions.BitmapScalingMode="Fant" Source="/Icons/Play.ico" />
        </Button>
    </Viewbox>
</UserControl>
