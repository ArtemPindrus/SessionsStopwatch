<Application x:Class="SessionsStopwatch.App"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:local="clr-namespace:SessionsStopwatch"
             xmlns:sys="clr-namespace:System;assembly=mscorlib">
    <Application.Resources>
        <sys:Double x:Key="MeatHeight">30</sys:Double>
        <sys:Double x:Key="MWWidth">100</sys:Double>
        <Style x:Key="MeatButton" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderBrush" Value="Transparent"/>
            <Setter Property="Width" Value="17"/>
            <Setter Property="Height" Value="17"/>
            <Setter Property="Margin" Value="3,0"/>
        </Style>
    </Application.Resources>
</Application>
