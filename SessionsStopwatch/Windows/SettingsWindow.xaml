<Window
    x:Class="SessionsStopwatch.SettingsWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="clr-namespace:SessionsStopwatch"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:views="clr-namespace:SessionsStopwatch.Views"
    Title="SettingsWindow"
    Width="250"
    Height="200"
    AllowsTransparency="True"
    Background="{StaticResource AppMeatBrush}"
    MouseLeftButtonDown="Window_MouseLeftButtonDown"
    ResizeMode="CanResizeWithGrip"
    Topmost="True"
    WindowStartupLocation="CenterScreen"
    WindowStyle="None"
    mc:Ignorable="d">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="{StaticResource HeaderHeight}" />
            <RowDefinition />
        </Grid.RowDefinitions>

        <Border Background="{StaticResource HeaderBrush}" />

        <StackPanel HorizontalAlignment="Right" Orientation="Horizontal">
            <Button
                Command="{Binding HideWindowCommand}"
                Content="X"
                Style="{StaticResource HeaderButton}" />
        </StackPanel>

        <Viewbox Grid.Row="1" Margin="3">
            <views:AppSettingsView />
        </Viewbox>
    </Grid>
</Window>
