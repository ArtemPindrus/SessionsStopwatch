<Window
    x:Class="SessionsStopwatch.Windows.AddAReminderWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="clr-namespace:SessionsStopwatch.Windows"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:views="clr-namespace:SessionsStopwatch.Views"
    Title="AddAReminderWindow"
    Width="150"
    Height="120"
    MouseDown="Window_MouseDown"
    ResizeMode="NoResize"
    Topmost="True"
    WindowStartupLocation="CenterScreen"
    WindowStyle="None"
    mc:Ignorable="d">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="{StaticResource HeaderHeight}" />
            <RowDefinition />
        </Grid.RowDefinitions>

        <Border Background="{StaticResource HeaderBrush}">
            <Button
                HorizontalAlignment="Right"
                Command="{Binding CloseWindowCommand}"
                Content="X"
                Style="{StaticResource HeaderButton}" />
        </Border>

        <Border Grid.Row="1" Background="{StaticResource BackgroundColor}">
            <Viewbox Margin="5">
                <views:AddAReminderView />
            </Viewbox>
        </Border>
    </Grid>
</Window>
