<Window
    x:Class="SessionsStopwatch.Windows.ReminderWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="clr-namespace:SessionsStopwatch.Windows"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    Title="ReminderWindow"
    Width="200"
    Height="100"
    AllowsTransparency="True"
    Background="{StaticResource AppMeatBrush}"
    ResizeMode="NoResize"
    Topmost="True"
    WindowStartupLocation="CenterScreen"
    WindowStyle="None"
    mc:Ignorable="d">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="{StaticResource HeaderHeight}" />
            <RowDefinition />
        </Grid.RowDefinitions>

        <Border Background="{StaticResource HeaderBrush}" />
        <Button
            HorizontalAlignment="Right"
            Command="{Binding CloseCommand}"
            Content="X"
            Style="{StaticResource HeaderButton}" />

        <Viewbox Grid.Row="1" Margin="5">
            <TextBlock Text="{Binding DisplayText, Mode=OneTime}" />
        </Viewbox>
    </Grid>
</Window>
